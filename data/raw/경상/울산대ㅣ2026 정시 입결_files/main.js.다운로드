		if(bbsId == 23 || bbsId == 0 || bbsId == 17){
			div = '';
		}
		
		// 게시물 불러오기
		$.ajax({
			url:'/mainBbs.do',
			method: 'post',
			data: {
				bbsId : bbsId,
				bbsArray : bbsArray,
				boardDiv : div,
				num: 10
			},
			success: function(data){
