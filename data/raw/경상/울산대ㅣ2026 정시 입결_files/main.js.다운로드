		slidesToScroll:1,
		prevArrow: $('.noti_prev'),
    	nextArrow: $('.noti_next'),
		accessibility: true,
		focusOnSelect: true,
        responsive:[
			{
		     	breakpoint: 1200,
		      		settings: {
		        	slidesToShow: 3
		      	}
		    },
			{
		     	breakpoint: 991,
		      		settings: {
		        	slidesToShow: 2
		      	}
		    },
			{
		     	breakpoint: 575,
		      		settings: {
		        	slidesToShow: 1
		      	}
		    },
		    
		]
    });

	
	// 공지사항 분류 BUTTON
	$(document).on('click', '.divBtn', function(){
