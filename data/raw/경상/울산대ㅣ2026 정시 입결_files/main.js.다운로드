				var html = "";
				
				//초기화
				$(".noti-area .list").slick('unslick');
				
				//owl 옵션 다시 셋팅
				var updatedOptions = {
			        infinite:false,
			        slidesToShow: 4,
					slidesToScroll:1,
					prevArrow: $('.noti_prev'),
			    	nextArrow: $('.noti_next'),
					accessibility: true,
					focusOnSelect: true,
			        responsive:[
						{
					     	breakpoint: 1200,
					      		settings: {
					        	slidesToShow: 3
					      	}
					    },
						{
					     	breakpoint: 991,
					      		settings: {
					        	slidesToShow: 2
					      	}
					    },
						{
					     	breakpoint: 575,
					      		settings: {
					        	slidesToShow: 1
					      	}
					    }
					    
					]
				};						
				
				for(var i=0; i<items.length; i++){
					if(items[i].stat == '1'){
						var classAdd = "";
						var boardDivd = items[i].boardDiv;
						var cdNm = items[i].cdNm;
						
						if(items[i].bbsId != 23 && items[i].bbsId != 17){
							if(boardDivd == '10001'){
